{
  "name": "tirocinium",
  "private": true,
  "version": "0.0.1",
  "description": "面接練習アプリ (ES/portfolio学習AI + 音声対話 + 複合LLM評価)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "dev:server": "npm --workspace apps/server run dev",
    "dev:desktop": "npm --workspace apps/desktop run dev",
    "build:server": "npm --workspace apps/server run build",
    "migrate": "npm --workspace apps/server run migrate",
    "seed-personas": "npm --workspace apps/server run seed-personas",
    "gen-qa-seed": "tsx scripts/gen-qa-seed/index.ts",
    "ft-loop": "tsx scripts/ft-loop/index.ts",
    "sim-loop": "tsx scripts/sim-loop/index.ts",
    "sim-batch": "tsx scripts/sim-batch/index.ts",
    "sim-viewer": "tsx scripts/sim-viewer/index.ts",
    "notion-crawl": "tsx scripts/notion-crawl/index.ts",
    "companies:seed-import:sqlite": "tsx scripts/companies-seed-import-sqlite/index.ts",
    "config-setup": "tsx scripts/config-setup/index.ts"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "UNLICENSED"
}
