# Tirocinium server config

TIROCINIUM_PORT=8084
TIROCINIUM_HOST=0.0.0.0

# Postgres (共有 infra)
DATABASE_URL=postgres://tirocinium:tirocinium@localhost:5432/tirocinium

# Cernere
CERNERE_PUBLIC_KEY=__paste_ed25519_public_key_pem_here__
CERNERE_AUDIENCE=tirocinium

# Reservation
SLOT_DURATION_MIN=30
SLOT_CAPACITY=4
NO_SHOW_TIMEOUT_MIN=5
NOTIFY_LEAD_MIN=15

# Nuntius (15 分前通知)
NUNTIUS_URL=http://localhost:3100
NUNTIUS_API_KEY=__set_me__
