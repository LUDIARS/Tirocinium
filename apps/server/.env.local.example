# Tirocinium server — Windows Local / dev プロファイル
# これを apps/server/.env.local にコピーして使う (gitignore 済)。
# サーバーモードのフル設定は .env.example を参照。

TIROCINIUM_PORT=8084
TIROCINIUM_HOST=127.0.0.1

# docker compose の Postgres (host port 15432)
DATABASE_URL=postgres://tirocinium:tirocinium@localhost:15432/tirocinium

# --- dev バイパス (本番では絶対に 1 にしない) ---
# Cernere を持たない 1 台環境で固定 dev ユーザとして面接を一周させる。
TIROCINIUM_DEV_AUTH=1
TIROCINIUM_DEV_USER_ID=00000000-0000-0000-0000-000000000001

# --- LLM バックエンド ---
# cli = 既ログインの claude CLI 経由 (ANTHROPIC_API_KEY 不要)。
# api = Anthropic SDK 直叩き (下の ANTHROPIC_API_KEY が必要、Opus 評価/GPT 補正も有効化)。
TIROCINIUM_LLM_BACKEND=cli

# Windows で claude CLI を spawn する場合に必須 (git-bash の bash.exe path)。
# 例: C:\Program Files\Git\bin\bash.exe
# CLAUDE_CODE_GIT_BASH_PATH=

# api バックエンド or Opus 評価を使う場合のみ設定:
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# 任意 (未設定なら RAG / 通知は skip):
# MEMORIA_URL=
# IV_URL=
# NUNTIUS_URL=
# NUNTIUS_API_KEY=
