{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tirocinium",
  "version": "0.0.1",
  "identifier": "ai.ludiars.tirocinium",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5178",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Tirocinium",
        "width": 1100,
        "height": 760,
        "minWidth": 880,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
